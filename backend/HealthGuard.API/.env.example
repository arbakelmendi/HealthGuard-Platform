# Copy this file to .env for local development. Never commit real secrets.
ConnectionStrings__DefaultConnection=Server=localhost;Database=HealthGuardDb;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;
Jwt__Key=replace-with-a-random-secret-at-least-32-characters-long
REDIS_CONNECTION=localhost:6379

# Initial admin seeding runs only when no admin account exists.
Admin__Email=admin@example.com
Admin__Password=replace-with-a-strong-admin-password

# External service configuration and optional API secrets.
ML_API_BASE_URL=http://localhost:8000
# ExternalApi__ApiKey=replace-with-api-key
